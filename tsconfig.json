{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler", // <--- CRUCIAL: Must be 'bundler' or 'node'
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "experimentalDecorators": true, // <--- Necessary for Lit decorators
    "emitDecoratorMetadata": true,
    "types": ["@storybook/test"] // <--- Tells TS where to find 'expect' and 'within'
  },
  "include": ["src"]
}
